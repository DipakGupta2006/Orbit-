<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>OrbitAI</title>

    <link rel="stylesheet" href="/css/home.css">

</head>


<body>


    <div class="stars-container" id="starsContainer">


        <div class="comet-container">


            <div class="app-container">



                <!-- SIDEBAR -->

                <aside class="sidebar">


                    <div class="sidebar-brand">
                        🪐 OrbitAI
                    </div>


                   
                   


                    <div class="project-item" style="margin-top: 30px;">

                        👤 <%= username || "guest" %>

                            <span class="badge">
                                Free
                            </span>

                    </div>


                    <div class="sidebar-footer">

                        <span>
                            OrbitAI v1.0
                        </span>

                        <span>
                            ✨ AI Assistant
                        </span>

                    </div>



                </aside>






                <!-- CHAT -->


                <main class="chat-main">



                    <div class="chat-header">

                        <h2>
                            OrbitAI
                        </h2>

                        <span>
                            🟢 Online
                        </span>

                    </div>





                    <div class="messages-area" id="messageArea">


                        <div class="message-item assistant">

                            ✦ OrbitAI is ready.

                            Ask me anything.

                        </div>


                    </div>






                    <div class="input-row">


                        <input id="chatInput" type="text" placeholder="Ask OrbitAI anything...">



                        <button id="sendBtn">
                            🚀 Send
                        </button>


                    </div>



                    <div class="status-note">

                        OrbitAI can make mistakes. Check important info.

                    </div>



                </main>



            </div>


        </div>


    </div>



    <script src="/js/home.js"></script>


</body>

</html>